# Keep the build context (and image) lean — the backend is the only thing
# that matters for the Render docker build.

# Frontend (built+deployed via Vercel, not Render)
frontend/

# Old streamlit / nightowl app remnants at repo root
nightowl/
ui.py
search.py
scrape.py
llm.py
llm_utils.py
health.py
config.py
Dockerfile
entrypoint.sh
requirements.txt

# Git + tooling
.git/
.github/
.claude/
.streamlit/
.vercel/
.vscode/

# Supabase migrations are applied out-of-band; not needed in the image
supabase/

# Caches
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Local secrets / env (defensive — these should already be gitignored too)
**/.env
**/.env.local
backend/.env

# Build / dist artifacts
**/node_modules/
**/.next/
**/dist/
**/build/
**/*.log

# Docs / OS junk
README.md
LICENSE
*.md
.DS_Store
Thumbs.db
logo.png
