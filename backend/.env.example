# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Intelligence APIs
HIBP_API_KEY=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
GITHUB_PAT=
GREYNOISE_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=
INTELX_API_KEY=
NVD_API_KEY=
RANSOMWARE_LIVE_API_KEY=

# New keyed providers
ABUSEIPDB_API_KEY=
IPQS_API_KEY=
NETLAS_API_KEY=
DNSDUMPSTER_API_KEY=

# Upstash Redis (REST API — get from console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ENRICHMENT_CACHE_TTL=86400

# MaxMind GeoLite2 — free signup at https://www.maxmind.com/en/geolite2/signup
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
GEOLITE2_CITY_DB=/tmp/GeoLite2-City.mmdb
GEOLITE2_ASN_DB=/tmp/GeoLite2-ASN.mmdb

# Notifications
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL_SECONDS=20

# theHarvester (assumes binary on PATH; install via `apt install theharvester` or pip)
HARVESTER_BIN=theHarvester
HARVESTER_TIMEOUT_SECONDS=120

# Maltego TRX server — optional shared secret all transforms must present
MALTEGO_TRX_AUTH_TOKEN=

# Modal — needed if backend calls Modal scanner functions
# Generate at https://modal.com/settings/tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# App
APP_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000
