      "name": "Anthropic Filter"
    },
    {
      "parameters": {
        "jsCode": "// Parse Claude's JSON array response and shape rows for Supabase\nconst resp = $input.first().json;\nconst text = resp?.content?.[0]?.text || '[]';\nlet cleaned = [];\ntry {\n  const m = text.match(/\\[[\\s\\S]*\\]/);\n  cleaned = JSON.parse(m ? m[0] : text);\n} catch (e) { cleaned = []; }\n\nconst ctx = $('Webhook').item.json.body;\nconst rows = cleaned.map(f => ({\n  tenant_id: ctx.tenant_id,\n  scan_run_id: ctx.run_id,\n  source: f.source,\n  kind: f.kind,\n  severity: f.severity,\n  confidence: typeof f.confidence === 'number' ? f.confidence : null,\n  url_or_value: f.url_or_value,\n  evidence: { summary: f.evidence_summary },\n  ai_filtered: true,\n  ai_reason: f.evidence_summary,\n  recommended_action: f.recommended_action,\n}));\n\n// Return ONE item carrying the whole array, plus a count for the next nodes\nreturn [{ json: { rows, count: rows.length } }];"
      },
