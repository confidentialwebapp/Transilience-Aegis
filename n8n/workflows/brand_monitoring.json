    {
      "parameters": {
        "jsCode": "// Flatten all 4 source outputs into a single array of {source, kind, value, evidence}\nconst raw = $input.all();\nconst out = [];\n\nconst pickArr = (n) => {\n  const j = raw[n]?.json;\n  if (!j) return [];\n  if (Array.isArray(j)) return j;\n  if (Array.isArray(j.body)) return j.body;\n  if (Array.isArray(j.organicResults)) return j.organicResults;\n  return [j];\n};\n\n// Index 0 = Apify google\nfor (const item of pickArr(0)) {\n  if (item?.organicResults) {\n    for (const r of item.organicResults) {\n      out.push({ source: 'apify:google-search', kind: 'web_search_hit', value: r.url,\n                 evidence: { title: r.title, description: r.description, query: item.searchQuery?.term } });\n    }\n  } else if (item?.url) {\n    out.push({ source: 'apify:google-search', kind: 'web_search_hit', value: item.url,\n               evidence: { title: item.title, description: item.description } });\n  }\n}\n\n// Index 1 = Apify Instagram\nfor (const item of pickArr(1)) {\n  if (!item) continue;\n  out.push({ source: 'apify:instagram', kind: 'social_handle_candidate',\n             value: item.username || item.url || '',\n             evidence: { full_name: item.fullName, followers: item.followersCount, is_private: item.private, bio: item.biography, url: item.url } });\n}\n\n// Index 2 = Kali Sherlock\nconst sherlock = raw[2]?.json || {};\nfor (const hit of (sherlock.hits || [])) {\n  out.push({ source: 'kali:sherlock', kind: 'username_squat', value: typeof hit === 'string' ? hit : (hit.url || JSON.stringify(hit)),\n             evidence: { username: sherlock.username, raw: hit } });\n}\n\n// Index 3 = HIBP\nfor (const breach of pickArr(3)) {\n  if (!breach || !breach.Name) continue;\n  out.push({ source: 'hibp', kind: 'credential_breach', value: breach.Name,\n             evidence: { breach_name: breach.Name, title: breach.Title, breach_date: breach.BreachDate,\n                         pwn_count: breach.PwnCount, data_classes: breach.DataClasses,\n                         description: breach.Description, domain: breach.Domain } });\n}\n\nreturn [{ json: { findings: out, count: out.length, context: $('Webhook').item.json.body } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
