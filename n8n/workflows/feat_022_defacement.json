          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "// FEAT-022 Defacement Detection \u2014 baseline capture\n// TODO: Implement diff against previous run by SELECTing last finding for same item_id\n//       and comparing dom_hash. Until then we emit Low severity baselines on every run;\n//       the diff logic should run in this same Code node once schema supports it.\nconst items = $input.all();\nconst ev = $('Webhook').item.json.body || {};\nconst headers = ev.headers || {};\nconst tenantId = headers['x-tenant-id'] || '23610954-5fd0-482f-8eb0-11edce1f5c58';\nconst taskId = ev.eventData?.actorTaskId || null;\nconst runId = ev.resource?.id || null;\nconst datasetId = ev.resource?.defaultDatasetId || null;\n\nconst rows = [];\nfor (const itm of items) {\n  const p = itm.json || {};\n  const url = p.url;\n  if (!url) continue;\n  rows.push({\n    tenant_id: tenantId,\n    apify_task_id: taskId,\n    apify_run_id: runId,\n    apify_dataset_id: datasetId,\n    feature_id: 'FEAT-022',\n    source: 'apify:web-scraper',\n    kind: 'defacement_baseline',\n    fraud_pattern: null,\n    severity: 'Low',\n    confidence: 0.5,\n    item_id: url,\n    url_or_value: url,\n    evidence: {\n      dom_hash: p.dom_hash,\n      title: p.title,\n      external_scripts: p.external_scripts || [],\n      captured_at: p.captured_at || new Date().toISOString(),\n    },\n    ai_filtered: false,\n    ai_reason: 'Baseline capture (defacement diff requires \u22652 runs)',\n    recommended_action: 'monitor',\n  });\n}\nreturn [{ json: { rows, count: rows.length } }];\n"
        },
